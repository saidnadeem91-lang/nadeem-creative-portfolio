# ─── NadeemCreative — Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# ── Contact Form (choose one provider) ───────────────────────────────────────

# Option A: EmailJS  https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Option B: Formspree  https://formspree.io/
VITE_FORMSPREE_ENDPOINT=

# Option C: Resend  https://resend.com/
VITE_RESEND_API_KEY=

# ── Analytics ────────────────────────────────────────────────────────────────

# Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site ─────────────────────────────────────────────────────────────────────

VITE_SITE_URL=https://nadeemcreative.com
